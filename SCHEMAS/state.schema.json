{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boundaryprotocol.org/schemas/state.schema.json",
  "title": "Boundary Protocol State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "state_id",
    "subject",
    "attributes",
    "observed_by",
    "observed_at"
  ],
  "properties": {
    "state_id": {
      "type": "string",
      "description": "Deterministic identifier of the state snapshot."
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "resource"],
      "properties": {
        "system": { "type": "string" },
        "resource": { "type": "string" }
      }
    },
    "attributes": {
      "type": "object",
      "description": "Observed attributes of the subject."
    },
    "observed_by": {
      "type": "string",
      "description": "Identity that produced this observation."
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence": {
      "type": ["object", "null"],
      "description": "Optional supporting evidence."
    }
  }
}