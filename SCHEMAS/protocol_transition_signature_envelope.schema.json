{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boundaryprotocol.org/schemas/protocol_transition_signature_envelope.schema.json",
  "title": "Protocol Transition Signature Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_ref",
    "signer_id",
    "signature_algorithm",
    "signature",
    "signed_at"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "artifact_ref": {
      "type": "string",
      "const": "protocol_transition_event.json"
    },
    "signer_id": {
      "type": "string",
      "minLength": 1
    },
    "signature_algorithm": {
      "type": "string",
      "minLength": 1
    },
    "signature": {
      "type": "string",
      "minLength": 1
    },
    "signed_at": {
      "type": "string",
      "format": "date-time"
    },
    "key_hint": {
      "type": "string",
      "minLength": 1
    }
  }
}
