{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boundaryprotocol.org/schemas/protocol_intent.schema.json",
  "title": "Boundary Protocol Authored Intent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "intent_id",
    "intent_type",
    "issuer",
    "issued_at",
    "target_profile",
    "target_subject",
    "requested_outcome",
    "evidence_refs"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "intent_id": {
      "type": "string",
      "description": "Deterministic identifier of the authored intent."
    },
    "intent_type": {
      "type": "string",
      "const": "sealed_run_verification"
    },
    "issuer": {
      "type": "string",
      "description": "Identity responsible for authoring the intent."
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "target_profile": {
      "type": "string",
      "description": "Profile or runtime scope the intent targets."
    },
    "target_subject": {
      "type": "string",
      "description": "Stable description of the sealed subject being verified."
    },
    "requested_outcome": {
      "type": "string",
      "description": "Minimal requested verification outcome."
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
