{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boundaryprotocol.org/schemas/protocol_dispute.schema.json",
  "title": "Boundary Protocol Dispute Publication",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dispute_id",
    "intent_ref",
    "transition_ref",
    "raised_by",
    "raised_at",
    "reason_code",
    "subject_ref"
  ],
  "properties": {
    "dispute_id": {
      "type": "string",
      "minLength": 1
    },
    "intent_ref": {
      "type": "string",
      "minLength": 1
    },
    "transition_ref": {
      "type": "string",
      "minLength": 1
    },
    "raised_by": {
      "type": "string",
      "minLength": 1
    },
    "raised_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason_code": {
      "type": "string",
      "minLength": 1
    },
    "subject_ref": {
      "type": "string",
      "enum": [
        "protocol_verdict.json",
        "protocol_attestation.json"
      ]
    },
    "supporting_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
