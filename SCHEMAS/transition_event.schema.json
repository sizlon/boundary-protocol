{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boundaryprotocol.org/schemas/transition_event.schema.json",
  "title": "Boundary Protocol Transition Event Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "intent_ref",
    "actor",
    "attempted_at",
    "outcome"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Deterministic identifier of the transition event artifact."
    },
    "intent_ref": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "attempted_at": {
      "type": "string",
      "format": "date-time"
    },
    "outcome": {
      "type": "string",
      "enum": ["success", "fail", "unknown"]
    },
    "from_state": {
      "type": ["string", "null"],
      "description": "Reference to prior observed state."
    },
    "to_state": {
      "type": ["string", "null"],
      "description": "Reference to resulting observed state."
    }
  }
}